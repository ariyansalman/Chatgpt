# ─── Phase 4: Example nginx reverse-proxy for webhook mode ───
# Place under /etc/nginx/sites-available/telegram-bot and enable with symlink.
# Requires a valid TLS cert (Let's Encrypt / certbot).

server {
    listen 443 ssl http2;
    server_name bot.example.com;

    ssl_certificate     /etc/letsencrypt/live/bot.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/bot.example.com/privkey.pem;

    # Telegram webhook → python-telegram-bot webhook server
    location /telegram {
        proxy_pass         http://127.0.0.1:8443/telegram;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    # Optional: CryptoBot webhook receiver (Flask, port 5000)
    location /webhook/cryptobot {
        proxy_pass         http://127.0.0.1:5000/webhook/cryptobot;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
    }
}

server {
    listen 80;
    server_name bot.example.com;
    return 301 https://$host$request_uri;
}
